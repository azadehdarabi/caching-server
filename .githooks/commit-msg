#!/bin/bash

# Commit Message Hook
# This hook validates commit messages against Conventional Commits specification
# Install: chmod +x .git/hooks/commit-msg
# Or use: npm run setup-hooks

# Get the commit message
COMMIT_MSG_FILE=$1
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" | head -n1)

# ANSI color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Regex pattern for conventional commits
# Format: type(scope): subject or type: subject
PATTERN="^(feat|fix|docs|style|refactor|perf|test|chore|ci|revert)(\(.+\))?!?:\s.{1,50}$"

echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${BLUE}🔍 Validating commit message...${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# Validate commit message
if [[ ! $COMMIT_MSG =~ $PATTERN ]]; then
    echo -e "${RED}❌ Commit message does not follow Conventional Commits${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo -e "${YELLOW}Your message:${NC}"
    echo -e "  ${RED}$COMMIT_MSG${NC}"
    echo ""
    echo -e "${YELLOW}Valid format:${NC}"
    echo -e "  ${GREEN}<type>(<scope>): <subject>${NC}"
    echo ""
    echo -e "${YELLOW}Examples:${NC}"
    echo -e "  ${GREEN}feat: add user authentication${NC}"
    echo -e "  ${GREEN}fix(cache): resolve memory leak${NC}"
    echo -e "  ${GREEN}docs: update README${NC}"
    echo -e "  ${GREEN}refactor(server): extract handler logic${NC}"
    echo ""
    echo -e "${YELLOW}Valid types:${NC}"
    echo -e "  feat, fix, docs, style, refactor, perf, test, chore, ci, revert"
    echo ""
    echo -e "${YELLOW}Rules:${NC}"
    echo -e "  • Use imperative mood (add, fix, refactor - not adds, fixed, refactored)"
    echo -e "  • Do not capitalize first letter after type"
    echo -e "  • Do not end with a period"
    echo -e "  • Subject should be 1-50 characters"
    echo -e "  • Scope is optional but recommended"
    echo ""
    echo -e "${YELLOW}Learn more: See COMMIT_MESSAGE_GUIDE.md${NC}"
    echo ""
    exit 1
fi

# Additional checks
SUBJECT_LENGTH=${#COMMIT_MSG}

# Warn if subject is close to 50 character limit
if [[ $SUBJECT_LENGTH -gt 45 ]]; then
    echo -e "${YELLOW}⚠️  Warning: Subject is ${SUBJECT_LENGTH} characters (aim for <50)${NC}"
fi

# Extract type
TYPE=$(echo "$COMMIT_MSG" | grep -oE "^[a-z]+" || true)

echo -e "${GREEN}✅ Valid commit message${NC}"
echo ""
echo -e "${BLUE}Details:${NC}"
echo -e "  Type: ${GREEN}$TYPE${NC}"
echo -e "  Length: ${GREEN}${SUBJECT_LENGTH} characters${NC}"
echo -e "  Message: ${GREEN}$COMMIT_MSG${NC}"
echo ""
echo -e "${GREEN}Commit will proceed.${NC}"
echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

exit 0
